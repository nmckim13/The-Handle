# Copy this file to `.env` and fill in the values, then `npm start`.

# LapMonitor live feed --------------------------------------------------------
# The roomID is the number in your LapMonitor Live URL:
#   https://lapmonitor.live/512060739  ->  512060739
LAPMONITOR_ROOM_ID=512060739

# Leave as-is unless the LapMonitor contact gives you a different host.
LAPMONITOR_SERVER=https://lapmonitor.live

# Set this ONLY if/when the official API gives you a token. Blank = none.
LAPMONITOR_AUTH_TOKEN=

# Supabase (yardkartz's own project) ------------------------------------------
SUPABASE_URL=https://lnsvacnbgmklpkgzbodb.supabase.co
# The anon key works (row-level security is open on this project, same as the
# site). Paste the anon key from admin/index.html / big-screen.html here.
SUPABASE_KEY=

# Optional: pin the race to write timing for. If blank, the bridge uses
# whichever race is currently marked live in the admin (live_state.is_live).
RACE_ID=

# How often (ms) to re-read driver->transponder assignments so transponders
# assigned mid-setup get picked up without restarting the bridge.
DRIVER_REFRESH_MS=30000
